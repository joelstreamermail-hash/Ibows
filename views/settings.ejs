<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <title><%= guildName %> Einstellungen</title>
    <style>
        body { font-family: sans-serif; background-color: #2c2f33; color: white; padding: 20px; }
        .card { background-color: #23272a; padding: 20px; margin: 10px 0; border-radius: 5px; border-left: 5px solid #7289da; }
        .btn { background-color: #7289da; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px; cursor: pointer; border: none; margin-top: 20px;}
        .logout { float: right; color: white; background-color: #555; padding: 10px; border-radius: 5px; text-decoration: none; }
        .form-group { margin-bottom: 20px; padding: 10px; border-bottom: 1px solid #444; }
        label { display: block; margin-bottom: 5px; font-weight: bold; }
        input[type="text"] { width: 100%; padding: 10px; border: 1px solid #444; border-radius: 3px; background-color: #36393f; color: white; box-sizing: border-box; }
        input[type="checkbox"] { margin-right: 10px; }
    </style>
</head>
<body>
    <a href="/dashboard" class="logout">Zurück zum Server-Menü</a>
    <h1>Einstellungen für <%= guildName %></h1>

    <form method="POST" action="/dashboard/<%= guildId %>/settings">
        <div class="card">
            <h2>Moderation & Logging</h2>
            
            <div class="form-group">
                <label for="modLogChannel">Moderations-Log Channel ID:</label>
                <input 
                    type="text" 
                    id="modLogChannel" 
                    name="modLogChannel" 
                    value="<%= settings.modLogChannelId || '' %>"
                    placeholder="Geben Sie die ID des Textkanals ein (z.B. 1234567890)"
                >
                <small>Hierhin sendet der Bot alle Log-Nachrichten (Dashboard-Änderungen).</small>
            </div>
            
            <div class="form-group">
                <label for="antiSpam">Anti-Spam Schutz:</label>
                <input 
                    type="checkbox" 
                    id="antiSpam" 
                    name="antiSpam" 
                    <%= settings.antiSpamEnabled ? 'checked' : '' %>
                >
                <small>Aktiviert die automatische Erkennung und Löschung von Spam-Nachrichten.</small>
            </div>
        </div>
        
        <button type="submit" class="btn">Einstellungen Speichern</button>
    </form>
</body>
</html>